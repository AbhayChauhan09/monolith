pipeline {
    agent { label 'agent' }

    stages {

        stage('Clone') {
            steps {
                echo 'Cloning done by Jenkins automatically'
            }
        }

        stage('Build') {
            steps {
                echo 'Building application...'
            }
        }

        stage('Test') {
            steps {
                echo 'Running tests...'
            }
        }

        stage('Deploy') {
            steps {
                echo 'Deploy stage running...'
            }
        }
    }
}
